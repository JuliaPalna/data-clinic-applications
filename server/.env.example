# Порт сервера
NODE_PORT=3004

# Секрет для JWT токенов (должен быть случайной строкой)
NODE_JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Количество раундов для хеширования пароля
SALT_ROUNDS=10

# Настройки MongoDB
NODE_MONGO_PASSWORD=mongopassword
NODE_MONGO_DB=clinic_db
NODE_MONGO_PORT=27017

# Окружение (development/production)
NODE_ENV=development
